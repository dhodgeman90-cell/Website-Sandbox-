<div class="cg">
  <div class="cg__head cg__inner">
    <nav class="cg__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="cg__crumbsep" aria-hidden="true">/</span>
      <span class="cg__crumbcur">{{ blog.title }}</span>
    </nav>
    <p class="cg__eyebrow">{{ section.settings.eyebrow | default: "Collector's Guides" }}</p>
    <h1 class="cg__title">{{ section.settings.heading | default: "Storage, preservation &amp; collecting, done right" }}</h1>
    {%- if section.settings.intro != blank -%}<p class="cg__intro">{{ section.settings.intro }}</p>{%- endif -%}
  </div>

  <div class="cg__grid cg__inner">
    {%- for article in blog.articles -%}
      <a class="cg__card" href="{{ article.url }}">
        <span class="cg__thumb-wrap">
          <span class="cg__banner">{{ article.title }}</span>
          {%- if article.image -%}
            <img class="cg__thumb" src="{{ article.image | image_url: width: 700 }}" alt="{{ article.title | escape }}" loading="lazy" width="700" height="467">
          {%- else -%}
            <span class="cg__thumb cg__thumb--ph"></span>
          {%- endif -%}
        </span>
        <span class="cg__cbody">
          {%- if article.tags.size > 0 -%}<span class="cg__ctag">{{ article.tags.first }}</span>{%- endif -%}
          <span class="cg__cx">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</span>
        </span>
      </a>
    {%- else -%}
      <p class="cg__empty">Guides are on the way.</p>
    {%- endfor -%}
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ request.origin | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ request.origin | append: blog.url | json }} }
  ]
}
</script>

{% stylesheet %}
  .cg {
    background: #1e1410;
    min-height: 60vh;
  }

  /* ── Header ── */
  .cg__head {
    padding: 80px 0 56px;
    border-bottom: 1px solid #1e1e1e;
  }

  .cg__crumbs {
    font-size: 0.65rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 18px;
  }

  .cg__crumbs a {
    color: #c9a96e;
    text-decoration: none;
  }

  .cg__crumbs a:hover {
    text-decoration: underline;
  }

  .cg__crumbsep {
    margin: 0 8px;
    color: #555;
  }

  .cg__crumbcur {
    color: #888;
  }

  .cg__eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 16px;
  }

  .cg__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: #ffffff;
    font-weight: 400;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .cg__intro {
    font-size: 0.92rem;
    color: #cccccc;
    max-width: 560px;
    margin: 22px 0 0;
    line-height: 1.7;
  }

  /* ── Card grid ── */
  .cg__grid {
    padding: 64px 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .cg__card {
    background: #2c1e12;
    border: 1px solid #1e1e1e;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .cg__card:hover {
    border-color: #c9a96e;
    transform: translateY(-3px);
  }

  /* ── Thumbnail + title banner ── */
  .cg__thumb-wrap {
    position: relative;
    display: block;
  }

  .cg__banner {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 16px 18px 30px;
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.3;
    color: #ffffff;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.82) 0%, rgba(0, 0, 0, 0.55) 55%, rgba(0, 0, 0, 0) 100%);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  .cg__thumb {
    aspect-ratio: 3 / 2;
    background: #0c0c0c;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cg__thumb--ph {
    aspect-ratio: 3 / 2;
    background: linear-gradient(135deg, #241a12, #120d0a);
  }

  /* ── Card body ── */
  .cg__cbody {
    padding: 20px 22px 24px;
    display: block;
  }

  .cg__ctag {
    font-size: 0.6rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #c9a96e;
    display: block;
    margin: 0 0 10px;
  }

  .cg__cx {
    font-size: 0.78rem;
    color: #cccccc;
    line-height: 1.6;
    margin: 0;
    display: block;
  }

  /* ── Empty state ── */
  .cg__empty {
    color: #888;
    padding: 40px 0;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 749px) {
    .cg__head {
      padding: 52px 0 36px;
    }

    .cg__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Shared inner utility (namespaced) ── */
  .cg__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media screen and (max-width: 749px) {
    .cg__inner {
      padding: 0 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Guides Hub",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collector's Guides" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Storage, preservation & collecting, done right" },
    { "type": "textarea", "id": "intro", "label": "Intro line", "default": "Practical guides for protecting and organizing a serious trading card collection." }
  ],
  "presets": []
}
{% endschema %}
