<section
  class="homepage-hero{% if section.settings.enable_ken_burns %} homepage-hero--kenburns{% endif %}"
  id="homepage-hero-{{ section.id }}"
>
  <div class="homepage-hero__slides">
    {%- assign slide_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.image_filename != blank -%}
        {%- assign slide_count = slide_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if slide_count > 0 -%}
      {%- assign rendered = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.image_filename != blank -%}
          <div
            class="homepage-hero__slide{% if rendered == 0 %} is-active{% endif %}"
            aria-hidden="true"
            {{ block.shopify_attributes }}
          >
            <div
              class="homepage-hero__slide-img"
              style="background-image: url('{{ block.settings.image_filename | asset_url }}');"
            ></div>
          </div>
          {%- assign rendered = rendered | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback so the hero is never empty {%- endcomment -%}
      <div class="homepage-hero__slide is-active" aria-hidden="true">
        <div
          class="homepage-hero__slide-img"
          style="background-image: url('{{ 'cnc-hero.jpg' | asset_url }}');"
        ></div>
      </div>
    {%- endif -%}
  </div>

  <div class="homepage-hero__fade"></div>

  <div class="homepage-hero__content">
    <p class="homepage-hero__eyebrow">✦ The Crown Jewel of Your Collection ✦</p>
    <h1 class="homepage-hero__headline">Elite Trading Card<br>Storage Cabinets</h1>
    <p class="homepage-hero__subhead">Designed for the serious collector. Artisanal-grade craftsmanship, precision hardware, total customization.</p>
    <div class="homepage-hero__ctas">
      <a href="/pages/build-your-cabinet" class="homepage-hero__btn homepage-hero__btn--primary">Design Your Cabinet</a>
      <a href="/pages/order-form" class="homepage-hero__btn homepage-hero__btn--outline">Get a Custom Quote</a>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('homepage-hero-{{ section.id }}');
    if (!root) return;
    var slides = root.querySelectorAll('.homepage-hero__slide');
    if (slides.length <= 1) return;

    var seconds = {{ section.settings.slide_duration | default: 6 }};
    var duration = seconds * 1000;
    var current = 0;

    setInterval(function () {
      slides[current].classList.remove('is-active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('is-active');
    }, duration);
  })();
</script>

{% stylesheet %}
  .homepage-hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #000000;
    overflow: hidden;
  }

  .homepage-hero__slides {
    position: absolute;
    inset: 0;
    opacity: 0.70;
  }

  .homepage-hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  .homepage-hero__slide.is-active {
    opacity: 1;
  }

  .homepage-hero__slide-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center center;
    transform-origin: center center;
    will-change: transform;
  }

  /* Ken Burns — only when enabled in the theme editor */
  @keyframes homepage-hero-kenburns {
    from {
      transform: scale(1) translate(0, 0);
    }
    to {
      transform: scale(1.12) translate(-2%, -1%);
    }
  }

  .homepage-hero--kenburns .homepage-hero__slide-img {
    animation: homepage-hero-kenburns 14s ease-in-out infinite alternate;
    animation-play-state: paused;
  }

  .homepage-hero--kenburns .homepage-hero__slide.is-active .homepage-hero__slide-img {
    animation-play-state: running;
  }

  /* Alternate the zoom direction so it never feels repetitive */
  .homepage-hero--kenburns .homepage-hero__slide:nth-child(even) .homepage-hero__slide-img {
    animation-direction: alternate-reverse;
  }

  .homepage-hero__fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.80) 100%);
  }

  .homepage-hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 120px 24px 140px;
    max-width: 820px;
    width: 100%;
  }

  .homepage-hero__headline {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 4.5vw, 3.25rem);
    color: #ffffff;
    font-weight: 400;
    line-height: 1.18;
    margin: 0 0 52px;
    letter-spacing: -0.01em;
  }

  .homepage-hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #c9a96e;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: var(--font-heading--family);
  }

  .homepage-hero__subhead {
    font-size: 1.05rem;
    color: #b5a898;
    max-width: 560px;
    margin: 1rem auto 1.75rem;
    line-height: 1.65;
  }

  .homepage-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .homepage-hero__btn {
    display: inline-block;
    padding: 13px 30px;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    font-family: var(--font-body--family);
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .homepage-hero__btn:hover {
    opacity: 0.75;
  }

  .homepage-hero__btn--primary {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #ffffff;
  }

  .homepage-hero__btn--outline {
    background-color: transparent;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.5);
  }

  /* Respect users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .homepage-hero__slide-img {
      animation: none !important;
      transform: none !important;
    }
  }

  @media screen and (max-width: 749px) {
    .homepage-hero {
      min-height: 75vh;
    }

    .homepage-hero__content {
      padding: 80px 24px 100px;
    }

    .homepage-hero__ctas {
      flex-direction: column;
      align-items: center;
    }

    .homepage-hero__btn {
      width: 100%;
      max-width: 260px;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homepage Hero",
  "settings": [
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Seconds per slide",
      "min": 4,
      "max": 10,
      "step": 1,
      "default": 6,
      "unit": "s"
    },
    {
      "type": "checkbox",
      "id": "enable_ken_burns",
      "label": "Enable Ken Burns zoom effect",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Cabinet image",
      "settings": [
        {
          "type": "text",
          "id": "image_filename",
          "label": "Image filename (in /assets)",
          "info": "Example: cabinet-hero-lakeshore-oak.jpg"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Slide label (editor only)"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Homepage Hero",
      "blocks": [
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-main.jpg", "label": "Main" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-black-matte.png", "label": "Black Matte" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-lakeshore-oak.jpg", "label": "Lakeshore Oak" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-white-gloss.png", "label": "White Gloss" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-acquedotti.jpg", "label": "Acquedotti" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-black-gloss.jpg", "label": "Black Gloss" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-plum-creek-unfinished.jpg", "label": "Plum Creek (Unfinished)" } },
        { "type": "slide", "settings": { "image_filename": "cabinet-hero-white-matte.jpg", "label": "White Matte" } }
      ]
    }
  ]
}
{% endschema %}
